{
  "functions": {
    "source": ".",
    "runtime": "nodejs22",
    "ignore": [
      "dist",
      "dist/**",
      "src",
      "src/**",
      "public",
      "public/**",
      "temp",
      "temp/**",
      ".git",
      ".git/**",
      ".claude",
      ".claude/**",
      "*.jsx",
      "*.md",
      "*.txt",
      "vite.config.js",
      "start.mjs",
      "kimi_*"
    ]
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
